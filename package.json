{
  "name": "@jdlien/validator",
  "version": "2.0.0",
  "type": "module",
  "packageManager": "pnpm@10.11.0",
  "module": "dist/validator.js",
  "types": "dist/Validator.d.ts",
  "files": [
    "dist"
  ],
  "description": "Validates and sanitizes the inputs in a form using native HTML attributes.",
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc --emitDeclarationOnly && pnpm build:demo",
    "size:wire": "node scripts/measure-wire-size.mjs",
    "preview": "vite preview",
    "test": "vitest",
    "coverage": "vitest --coverage",
    "build:demo": "tsc demo/form-field.ts --outDir demo --target ES2020 --module ES2020 --skipLibCheck && tsc demo/dark-toggle.ts --outDir demo --target ES2020 --module ES2020 --skipLibCheck && node scripts/build-demo.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jdlien/validator.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "form",
    "validation",
    "front-end",
    "better",
    "HTML",
    "inputs",
    "date",
    "time",
    "color",
    "required",
    "field"
  ],
  "author": "JD Lien",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/jdlien/validator/issues"
  },
  "homepage": "https://github.com/jdlien/validator#readme",
  "devDependencies": {
    "@sheerun/mutationobserver-shim": "^0.3.3",
    "@tailwindcss/vite": "^4.1.18",
    "@types/jsdom": "^27.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "canvas": "^3.2.1",
    "jsdom": "^27.4.0",
    "jsdom-global": "^3.0.2",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "undici-types": "^7.19.1",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "sideEffects": false,
  "dependencies": {
    "@jdlien/validator-utils": "^2.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "canvas",
      "esbuild"
    ]
  }
}
