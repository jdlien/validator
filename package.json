{
  "name": "@jdlien/validator",
  "version": "2.0.1",
  "type": "module",
  "packageManager": "pnpm@10.11.0",
  "main": "dist/validator.cjs",
  "module": "dist/validator.mjs",
  "types": "dist/Validator.d.ts",
  "exports": {
    ".": {
      "types": "./dist/Validator.d.ts",
      "import": "./dist/validator.mjs",
      "require": "./dist/validator.cjs",
      "default": "./dist/validator.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "unpkg": "dist/validator.js",
  "jsdelivr": "dist/validator.js",
  "description": "Validates and sanitizes the inputs in a form using native HTML attributes.",
  "scripts": {
    "dev": "vite",
    "build:lib": "pnpm build:lib:esm && pnpm build:lib:compat && tsc --emitDeclarationOnly",
    "build:lib:esm": "vite build",
    "build:lib:compat": "vite build --mode compat",
    "build": "pnpm build:lib && pnpm build:demo",
    "size:wire": "node scripts/measure-wire-size.mjs",
    "preview": "vite preview",
    "test": "vitest",
    "coverage": "vitest --coverage",
    "build:demo": "tsc --ignoreConfig demo/form-field.ts --outDir demo --target ES2020 --module ES2020 --skipLibCheck && tsc --ignoreConfig demo/form-card.ts --outDir demo --target ES2020 --module ES2020 --skipLibCheck && tsc --ignoreConfig demo/dark-toggle.ts --outDir demo --target ES2020 --module ES2020 --skipLibCheck && node scripts/build-demo.mjs",
    "prepublishOnly": "pnpm build:lib"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jdlien/validator.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "form",
    "validation",
    "front-end",
    "better",
    "HTML",
    "inputs",
    "date",
    "time",
    "color",
    "required",
    "field"
  ],
  "author": "JD Lien",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/jdlien/validator/issues"
  },
  "homepage": "https://github.com/jdlien/validator#readme",
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/jsdom": "^28.0.3",
    "@vitest/coverage-v8": "^4.1.6",
    "canvas": "^3.2.3",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  },
  "sideEffects": false,
  "dependencies": {
    "@jdlien/validator-utils": "^2.2.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "canvas",
      "esbuild"
    ]
  }
}
